# OpenSky Network credentials (register at opensky-network.org)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Polling interval in milliseconds (default: 90000)
OPENSKY_POLL_INTERVAL_MS=90000

# Server port (default: 3000)
PORT=3000

# Neon PostgreSQL database
DATABASE_URL=

# Shared bearer token for protected Vercel cron endpoints
CRON_SECRET=

# Upstash Redis presence tracking
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AWS Serverless cron alerting
AWS_REGION=eu-central-1
AWS_ENABLE_BUDGET_ALERTS=false
AWS_CRON_BUDGET_ALERT_EMAIL=
AWS_CRON_BUDGET_LIMIT_USD=1
