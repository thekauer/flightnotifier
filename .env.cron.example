# AWS deployment configuration
AWS_REGION=eu-central-1
AWS_ENABLE_BUDGET_ALERTS=false
AWS_CRON_BUDGET_ALERT_EMAIL=
AWS_CRON_BUDGET_LIMIT_USD=1

# Runtime credentials for the cron Lambdas
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
DATABASE_URL=

# Deployment credentials can come from `aws configure` or be set here
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=
